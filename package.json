{
  "name": "sitesonar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sitesonar — self-hosted scraping + SEO audit HTTP API. Playwright + Crawlee + Lighthouse behind Fastify.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "cheerio": "^1.0.0",
    "chrome-launcher": "^1.1.2",
    "crawlee": "^3.12.0",
    "domhandler": "^5.0.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "lighthouse": "^12.3.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "structured-data-testing-tool": "^4.5.0",
    "turndown": "^7.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
