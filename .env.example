# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Auth: comma-separated list of valid API keys. Callers send Authorization: Bearer <key>.
# Generate with: echo "ss_live_$(openssl rand -hex 32)"
# (the ss_live_ prefix is a cosmetic convention; the server accepts any string)
API_KEYS=replace-me-with-a-real-key

# CORS: comma-separated origins. Use "*" to allow any (not recommended for prod).
CORS_ORIGINS=*

# Crawl limits (applied per-request unless overridden in the request body)
CRAWL_MAX_REQUESTS=50
CRAWL_DEFAULT_CONCURRENCY=5

# Per-request hard timeouts (ms)
SCRAPE_TIMEOUT_MS=30000
AUDIT_TIMEOUT_MS=90000
SCREENSHOT_TIMEOUT_MS=20000
SECURITY_TIMEOUT_MS=10000
ROBOTS_TIMEOUT_MS=10000
SITEMAP_TIMEOUT_MS=15000
EXTRACT_TIMEOUT_MS=30000
TECH_TIMEOUT_MS=30000
PDF_TIMEOUT_MS=60000

# Browser pool. Each context is ~50-150MB RAM. Increase for parallel
# PDF/screenshot/render throughput (raise this when Sitesonar replaces
# browserless for high-concurrency workloads).
BROWSER_POOL_SIZE=8

# Crawlee state directory (request queues, dataset). Wiped on container restart unless mounted.
CRAWLEE_STORAGE_DIR=/tmp/crawlee

# Optional outbound proxy for Playwright + Crawlee.
# Format: http(s)://[user:pass@]host:port or socks5://host:port
# Leave blank to disable. Auth is parsed from the URL.
PROXY_URL=
PROXY_BYPASS=

# Optional Redis for persistent job state (survives restarts, multi-replica safe).
# Leave blank to use the in-memory store (default, fine for single-instance).
# Shared by job storage, rate-limit counters, and change-tracking hashes.
REDIS_URL=
JOB_TTL_SECONDS=86400

# Per-API-key rate limit. Fixed 60-second window. Exceeded calls receive
# HTTP 429 with Retry-After and X-RateLimit-* headers. Calling /v1/usage
# is exempt (free to poll your own quota).
RATE_LIMIT_PER_MIN=60

# Webhook signing secret. When set, the body of every webhook POST is
# HMAC-SHA256-signed and the digest sent in X-Sitesonar-Signature: sha256=...
# When unset, the header is the literal "unsigned" — receivers should refuse.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# How long change-tracking content hashes are retained (per API key + URL).
# Increase if callers expect to detect changes against older baselines.
DIFF_TTL_DAYS=30

# Web search providers for /v1/search. Configure at least one to enable the
# endpoint. The SEARCH_PROVIDERS list defines the fallback order — providers
# without credentials are skipped automatically.
SEARCH_PROVIDERS=searxng,brave,google,serpapi,serper,tavily
SEARCH_TIMEOUT_MS=8000

# SearXNG — self-hosted meta-search. JSON output must be enabled on the
# instance (settings.yml: search.formats includes 'json'). Free, no key.
SEARXNG_URL=

# Brave Search API — 2,000 queries/mo free. https://api.search.brave.com
BRAVE_SEARCH_API_KEY=

# Google Custom Search — 100 queries/day free. Requires a Custom Search
# Engine ID (cx) configured at programmablesearchengine.google.com.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# SerpAPI — 100 queries/mo free. Real Google SERPs with the richest feature
# coverage. NOT the same service as Serper.dev (similar name, different API).
# https://serpapi.com
SERPAPI_KEY=

# Serper.dev — ~2,500 free credits on sign-up. Real Google SERPs with rich
# features (PAA, knowledge graph, answer box). NOT the same service as
# SerpAPI. https://serper.dev
SERPER_API_KEY=

# Tavily — 1,000 queries/mo free. LLM-optimized clean results, no SERP
# features. https://tavily.com
TAVILY_API_KEY=

# /v1/company firmographics — provider fallback chain. Comma-separated
# list defines the order. Providers without credentials are skipped
# automatically. The chain stops at the first provider that returns a
# match. Three providers need no API key:
#   schema_org  — fetches the company's homepage and parses Schema.org
#                 JSON-LD (Organization markup). Works for ~50-70% of
#                 B2B sites with proper SEO. Free, unlimited.
#   wikidata    — SPARQL query against query.wikidata.org. Reliable for
#                 well-known companies (~Fortune 5000-ish), sparse for
#                 SMBs. Free, unlimited (60 req/min soft cap).
#   rdap        — registrar lookup. Almost always returns nothing useful
#                 post-GDPR for .com domains. Keep as last-ditch.
COMPANY_PROVIDERS=hunter,google_places,schema_org,wikidata,rdap
COMPANY_TIMEOUT_MS=15000

# Hunter — richest free firmographics. 25 lookups/mo free, then paid.
# Returns name, legal name, founded year, employees, address, socials,
# industry. Also used by /v1/company when contacts include emails.
# https://hunter.io/api-keys
HUNTER_API_KEY=

# Google Places (New) — operational location data. $200/mo free credit
# (~6,500 Text Search calls). Enable "Places API (New)" in Google Cloud
# Console. Supports `location` for multi-office disambiguation.
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=

# /v1/company contacts — provider fallback chain. Comma-separated list
# defines the order. Hunter uses /v2/domain-search (returns names + work
# emails + titles, uses HUNTER_API_KEY's 25 free searches/mo). Apollo
# uses /v1/mixed_people/search which requires a *paid* Apollo plan;
# free Apollo keys 403 on this endpoint.
CONTACTS_PROVIDERS=hunter,apollo

# Apollo.io — professional contacts at a company domain. Note: people
# search requires a paid plan; the free tier returns 403 for this
# endpoint. Configure if you have a paid Apollo plan; otherwise rely on
# Hunter for contacts.
# https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=
