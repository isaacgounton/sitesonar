# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Auth: comma-separated list of valid API keys. Callers send Authorization: Bearer <key>.
# Generate with: echo "ss_live_$(openssl rand -hex 32)"
# (the ss_live_ prefix is a cosmetic convention; the server accepts any string)
API_KEYS=replace-me-with-a-real-key

# CORS: comma-separated origins. Use "*" to allow any (not recommended for prod).
CORS_ORIGINS=*

# Crawl limits (applied per-request unless overridden in the request body)
CRAWL_MAX_REQUESTS=50
CRAWL_DEFAULT_CONCURRENCY=5

# Per-request hard timeouts (ms)
SCRAPE_TIMEOUT_MS=30000
AUDIT_TIMEOUT_MS=90000
SCREENSHOT_TIMEOUT_MS=20000

# Browser pool
BROWSER_POOL_SIZE=3

# Crawlee state directory (request queues, dataset). Wiped on container restart unless mounted.
CRAWLEE_STORAGE_DIR=/tmp/crawlee

# Optional outbound proxy for Playwright + Crawlee.
# Format: http(s)://[user:pass@]host:port or socks5://host:port
# Leave blank to disable. Auth is parsed from the URL.
PROXY_URL=
PROXY_BYPASS=

# Optional Redis for persistent job state (survives restarts, multi-replica safe).
# Leave blank to use the in-memory store (default, fine for single-instance).
REDIS_URL=
JOB_TTL_SECONDS=86400
